"""
ENVIRONMENT VARIABLES TEMPLATE

Copy this to:
- .env (local development)
- HuggingFace Spaces: Settings → Secrets
- Google Colab: Cell near top

Instructions:
1. Get SUPABASE_URL and SUPABASE_KEY from Supabase dashboard
   → Settings → API → Copy URL and "anon public" key
2. Get HF_TOKEN from HuggingFace
   → Settings → Access Tokens → New token (select "Read" access)
3. Fill in API_BASE after you deploy HF Space
   → You'll see URL like: https://username-videntia-api.hf.space
"""

# =====================================================
# DATABASE (Supabase)
# =====================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your-long-key...

# =====================================================
# MODELS & CREDENTIALS (HuggingFace)
# =====================================================
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =====================================================
# API ENDPOINTS
# =====================================================
# Your HuggingFace Space URL (for API calls)
API_BASE=https://username-videntia-api.hf.space

# Ngrok tunnel (for Colab webhooks)
NGROK_TOKEN=2_abc123def456...your-ngrok-token...

# =====================================================
# LLM (Groq — required for the agent pipeline)
# =====================================================
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxx

# =====================================================
# CI/CD — GitHub Actions Secrets
# (add these in GitHub → Settings → Secrets → Actions)
# =====================================================
# Vercel deployment
VERCEL_TOKEN=your_vercel_token          # vercel.com/account/tokens
VERCEL_ORG_ID=your_org_id              # from .vercel/project.json after `vercel link`
VERCEL_PROJECT_ID=your_project_id      # from .vercel/project.json after `vercel link`

# Hugging Face Spaces deployment
HF_SPACE_NAME=yourname/videntia-api    # e.g. "johndoe/videntia-api"
# HF_TOKEN is already defined above

# =====================================================
# OPTIONAL: Other LLM providers
# =====================================================
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx
# TOGETHER_API_KEY=xxxxxxxxxxxxxxxxxxxxx  # optional, not required

# =====================================================
# CONFIGURATION
# =====================================================
# Processing settings
CHUNK_SIZE=5  # minutes per chunk
BATCH_SIZE=10  # segments per batch processing
MAX_WORKERS=4  # parallel workers

# Safety thresholds
MIN_CONFIDENCE=0.75  # minimum confidence threshold
MAX_ITERATIONS=5  # max agent iterations

# =====================================================
# STEP-BY-STEP: HOW TO GET EACH VALUE
# =====================================================

# 1. SUPABASE_URL
# → Go to https://supabase.com
# → Log in → Select your project
# → Click Settings (bottom left)
# → Click "API"
# → Copy the URL that looks like: https://xxxxx.supabase.co
# → Paste above

# 2. SUPABASE_KEY
# → Same Settings → API page
# → Look for "anon public" key
# → It starts with "eyJhbGci..." and is VERY long
# → Copy and paste above
# → ⚠️ NEVER use SERVICE_ROLE_KEY (that's for backend only)

# 3. HF_TOKEN
# → Go to https://huggingface.co/settings/tokens
# → Click "New token"
# → Give it a name: "videntia"
# → Select "Read" access
# → Click "Generate token"
# → Copy the new token (starts with "hf_")
# → Paste above

# 4. API_BASE
# → Deploy to HuggingFace Spaces (see QUICKSTART_GUIDE.md)
# → Your space will get a URL like:
#   https://username-videntia-api.hf.space
# → Replace "username" with your actual username
# → Copy full URL above

# 5. NGROK_TOKEN (optional, for advanced webhooks)
# → Go to https://ngrok.com
# → Sign up free
# → Go to Dashboard → Auth Token
# → Copy token
# → Paste above
# → Use in Google Colab for tunneling

